# Qwen AI Reverse API 环境变量配置示例

# ==================== JWT Token 配置 ====================
# 设置你的 JWT Token（支持多个，用逗号分隔）
# QWEN_TOKENS="your_token_1,your_token_2"

# ==================== Vless 订阅配置 ====================
# 订阅URL（支持多个，用逗号、分号或换行分隔）
VLESS_SUBSCRIPTION_URLS="https://example.com/subscription1,https://example.com/subscription2"

# 节点匹配规则（支持多个，用逗号分隔）
# 例如：CF优选-电信, CF优选-移动, CF优选-联通
VLESS_SUBSCRIPTION_PATTERNS="CF优选-电信"

# 启动时自动刷新订阅
VLESS_AUTO_REFRESH_ON_START=true

# 节点存储文件路径
VLESS_STORAGE_FILE="vless_nodes.json"

# ==================== 普通代理配置（可选） ====================
# HTTP 代理
HTTP_PROXY=""
HTTPS_PROXY=""

# Vless 代理文件（每行一个 Vless URI）
VLESS_PROXY_FILE=""

# 直接设置 Vless URI（不通过订阅）
# VLESS_PROXIES="vless://uuid@host:port?security=tls...,vless://..."

# ==================== 服务配置 ====================
# 服务监听地址和端口
HOST="0.0.0.0"
PORT="8000"

# 调试模式
DEBUG=false

# ==================== 对话配置 ====================
# 自动删除对话（对话完成后删除网页对话记录）
AUTO_DELETE_CHAT=false
