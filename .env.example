# Qwen AI Reverse API 配置
# 复制此文件为 .env 并修改配置

# ==================== 服务配置 =====================
HOST="0.0.0.0"
PORT="8000"
DEBUG="false"
AUTO_DELETE_CHAT="false"

# ==================== 代理配置 =====================
# 是否启用代理功能 (true/false)
PROXY_ENABLED="false"

# ==================== Vless 订阅配置 =====================
# 多个订阅链接用逗号分隔
VLESS_SUBSCRIPTION_URLS=""
# 节点匹配规则，多个规则用逗号分隔
VLESS_SUBSCRIPTION_PATTERNS="CF优选-电信"
VLESS_AUTO_REFRESH_ON_START="true"
VLESS_STORAGE_FILE="vless_nodes.json"
